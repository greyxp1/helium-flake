#!/usr/bin/env bash
set -euo pipefail

[ "$#" -eq 1 ] || { echo "Usage: ./update <version>" >&2; exit 1; }
version="$1"
url="https://github.com/imputnet/helium-linux/releases/download/$version/helium-$version-x86_64_linux.tar.xz"
hash=$(nix store prefetch-file --hash-type sha256 --json "$url" | sed -n 's/.*"hash": *"\([^"]*\)".*/\1/p')
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
sed \
  -e "s|version = \".*\";|version = \"$version\";|" \
  -e "s|hash = \".*\";|hash = \"$hash\";|" \
  modules/sources.nix > "$tmp"
mv "$tmp" modules/sources.nix
